---
import { soalDatabase } from '../data/Soal';
import crypto from 'node:crypto';

const SALT = "tinkers_sec_2026_salt";

// Map the questions to remove plain text answers and replace with secure SHA-256 hashes
const safeSoalDatabase = soalDatabase.map(q => {
  const hash = crypto
    .createHash('sha256')
    .update(`${q.id}-${q.answer}-${SALT}`)
    .digest('hex');
    
  return {
    id: q.id,
    category: q.category,
    question: q.question,
    options: q.options,
    answerHash: hash
  };
});
---

<div id="hyper-container" class="min-h-screen bg-[#090d16] text-slate-100 selection:bg-indigo-500 selection:text-white relative overflow-x-hidden">
    
    <!-- Ambient Aurora Glows -->
    <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[40%] -left-[20%] w-[80%] h-[80%] rounded-full bg-indigo-500/10 blur-[150px] animate-pulse"></div>
        <div class="absolute -bottom-[40%] -right-[20%] w-[80%] h-[80%] rounded-full bg-violet-500/10 blur-[150px] animate-pulse delay-1000"></div>
    </div>

    <!-- Main Container -->
    <div id="main-frame" class="min-h-screen flex items-center justify-center p-4 md:p-8 relative z-10 w-full max-w-6xl mx-auto">
        
        <!-- Intro Screen -->
        <div id="intro-card" class="w-full max-w-xl bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-8 md:p-12 rounded-3xl shadow-2xl transition-all duration-500">
            <div class="text-center">
                <img src="/the_tinkers.png" class="w-24 h-24 mx-auto mb-6 object-contain invert opacity-90" />
                <h1 class="text-3xl font-extrabold text-white tracking-tight mb-2">KUIS SELEKSI</h1>
                <p class="text-indigo-400 font-semibold tracking-wider uppercase text-sm mb-6">The Tinkers - Batch 2</p>
                <div class="w-16 h-1 bg-indigo-500 mx-auto rounded-full mb-8"></div>
            </div>
            
            <div class="space-y-6">
                <div>
                    <label for="user-name" class="block text-xs font-semibold uppercase text-slate-400 tracking-wider mb-2">Nama Lengkap Peserta</label>
                    <input 
                        type="text" 
                        id="user-name" 
                        placeholder="Masukkan nama Anda..." 
                        class="w-full bg-slate-950/80 border border-slate-800 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-2xl px-5 py-4 text-white text-lg font-medium transition-all placeholder:text-slate-600 outline-none"
                    />
                </div>
                
                <button id="start-btn" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-2xl transition-all duration-300 transform active:scale-[0.98] shadow-lg shadow-indigo-600/20 disabled:opacity-30 disabled:pointer-events-none" disabled>
                    Mulai Ujian
                </button>
            </div>
        </div>

        <!-- Booting screen (simple clean fade loader) -->
        <div id="booting-screen" class="fixed inset-0 z-50 bg-[#090d16] flex flex-col items-center justify-center hidden opacity-0 transition-opacity duration-500">
            <div class="w-12 h-12 border-4 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin mb-4"></div>
            <p class="text-slate-400 font-medium text-sm">Mempersiapkan soal...</p>
        </div>

        <!-- Main Quiz Interface -->
        <div id="quiz-interface" class="hidden opacity-0 w-full grid grid-cols-12 gap-6 md:gap-8 items-start transition-all duration-500">
            
            <!-- Left Panel: Profile & Category Progress -->
            <div class="col-span-12 lg:col-span-4 space-y-6">
                <div class="bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-6 rounded-2xl shadow-xl">
                    <div class="flex items-center space-x-4 mb-6">
                        <div class="w-14 h-14 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center">
                            <img id="mascot-img" src="/the_tinkers.png" class="w-8 h-8 object-contain invert opacity-95" />
                        </div>
                        <div>
                            <span class="text-xs text-slate-400 font-semibold tracking-wider uppercase">Peserta</span>
                            <h2 id="operator-label" class="text-lg font-bold text-white leading-tight truncate">CANDIDATE</h2>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex justify-between text-xs font-semibold text-slate-400 tracking-wider">
                            <span>PROGRES KESELURUHAN</span>
                            <span id="progress-percent">0%</span>
                        </div>
                        <div class="h-2 w-full bg-slate-950 rounded-full overflow-hidden">
                            <div id="progress-bar" class="h-full bg-gradient-to-r from-indigo-500 to-violet-500 w-0 transition-all duration-500 rounded-full"></div>
                        </div>
                    </div>
                </div>

                <!-- Category Breakdown Stats -->
                <div class="bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-6 rounded-2xl shadow-xl">
                    <h3 class="text-xs font-bold text-slate-400 tracking-wider uppercase mb-4">Kategori Kompetensi</h3>
                    <div class="space-y-4" id="categories-stat">
                        <!-- Stat items will be injected here dynamically -->
                    </div>
                </div>
            </div>

            <!-- Right Panel: Questions and Options -->
            <div class="col-span-12 lg:col-span-8 space-y-6">
                <div class="bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-8 md:p-12 rounded-3xl shadow-xl min-h-[420px] flex flex-col justify-between relative overflow-hidden">
                    <div>
                        <!-- Category Badge & Index -->
                        <div class="flex justify-between items-center mb-8">
                            <span id="cat-badge" class="px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-400 text-xs font-bold tracking-wider uppercase">KATEGORI</span>
                            <span class="text-slate-500 text-sm font-semibold">Soal <span id="current-num" class="text-white font-bold">01</span> / 50</span>
                        </div>

                        <!-- Question Text -->
                        <h2 id="question-text" class="text-xl md:text-2xl font-bold text-white leading-relaxed mb-10">
                            <!-- Question text loaded here -->
                        </h2>
                    </div>

                    <!-- Options Grid -->
                    <div id="options-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-auto">
                        <!-- Options buttons injected here -->
                    </div>
                </div>

                <!-- Navigation Controls -->
                <div class="flex justify-between items-center bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-4 rounded-2xl shadow-xl">
                    <button id="nav-prev" class="px-5 py-3 text-slate-400 hover:text-white font-semibold text-sm transition-all disabled:opacity-0" disabled>
                        ← Kembali
                    </button>
                    <button id="nav-next" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-sm rounded-xl transition-all disabled:opacity-30 disabled:pointer-events-none" disabled>
                        Lanjut →
                    </button>
                </div>
            </div>
        </div>

        <!-- Result Screen -->
        <div id="result-screen" class="hidden opacity-0 max-w-2xl w-full bg-slate-900/60 backdrop-blur-xl border border-slate-800 p-8 md:p-16 rounded-3xl shadow-2xl text-center transition-all duration-500">
            <img src="/the_tinkers.png" class="w-20 h-20 mx-auto mb-6 object-contain invert opacity-90" />
            <h2 class="text-indigo-400 text-sm font-bold tracking-widest uppercase mb-2">Evaluasi Selesai</h2>
            <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-8">HASIL EVALUASI</h1>

            <div class="grid grid-cols-3 gap-4 md:gap-6 mb-8 text-left">
                <div class="bg-slate-950/50 border border-slate-800 p-5 rounded-2xl">
                    <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Nama</p>
                    <p id="final-operator" class="text-base font-bold text-white truncate">GUEST</p>
                </div>
                <div class="bg-slate-950/50 border border-slate-800 p-5 rounded-2xl">
                    <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Akurasi</p>
                    <p id="accuracy-val" class="text-lg md:text-xl font-bold text-emerald-400">0%</p>
                </div>
                <div class="bg-slate-950/50 border border-slate-800 p-5 rounded-2xl">
                    <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Skor</p>
                    <p id="final-score-val" class="text-lg md:text-xl font-bold text-indigo-400">0</p>
                </div>
            </div>

            <div class="bg-slate-950/50 border border-slate-800 py-6 px-8 rounded-2xl mb-10">
                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Rekomendasi Jabatan</p>
                <h3 id="rank-title" class="text-xl md:text-2xl font-extrabold text-white tracking-wide uppercase">ANALYST</h3>
            </div>

            <button id="restart-final" class="w-full md:w-auto px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-2xl transition-all shadow-lg shadow-indigo-600/10">
                Ulangi Kuis
            </button>
        </div>

    </div>
</div>

<script define:vars={{ safeSoalDatabase, SALT }}>
    const soalDatabase = safeSoalDatabase;
    let activeQuestions = [];
    let currentIdx = 0;
    let userSelections = [];
    let isCorrectArray = [];
    let operatorName = "";
    let proficiency = { 'IoT': 0, 'Game': 0, 'Web': 0, 'Logika': 0, 'Inovatif': 0 };

    // DOM Elements
    const root = document.getElementById('hyper-container');
    const mainFrame = document.getElementById('main-frame');
    const introCard = document.getElementById('intro-card');
    const quizInterface = document.getElementById('quiz-interface');
    const resultScreen = document.getElementById('result-screen');
    const startBtn = document.getElementById('start-btn');
    const nameInput = document.getElementById('user-name');
    const operatorLabel = document.getElementById('operator-label');
    const finalOperator = document.getElementById('final-operator');
    const mascotImg = document.getElementById('mascot-img');
    const bootingScreen = document.getElementById('booting-screen');
    
    const questionText = document.getElementById('question-text');
    const optionsGrid = document.getElementById('options-grid');
    const nextBtn = document.getElementById('nav-next');
    const prevBtn = document.getElementById('nav-prev');
    const progressBar = document.getElementById('progress-bar');
    const progressPercent = document.getElementById('progress-percent');
    const catBadge = document.getElementById('cat-badge');
    const currentNum = document.getElementById('current-num');
    const finalScoreVal = document.getElementById('final-score-val');
    const accuracyVal = document.getElementById('accuracy-val');
    const rankTitle = document.getElementById('rank-title');
    const restartBtn = document.getElementById('restart-final');

    const themeMap = {
        'IoT': { color: '#06b6d4', text: 'text-cyan-400' },
        'Game': { color: '#a855f7', text: 'text-purple-400' },
        'Web': { color: '#10b981', text: 'text-emerald-400' },
        'Logika': { color: '#6366f1', text: 'text-indigo-400' },
        'Inovatif': { color: '#f59e0b', text: 'text-amber-400' }
    };

    const mascotMap = {
        'IoT': '/m_iot.png',
        'Web': '/m_web.png',
        'Game': '/m_game.png',
        'Logika': '/the_tinkers.png',
        'Inovatif': '/the_tinkers.png'
    };

    // Secure browser hashing using SubtleCrypto API
    async function sha256(message) {
        const msgBuffer = new TextEncoder().encode(message);
        const hashBuffer = await window.crypto.subtle.digest('SHA-256', msgBuffer);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    }

    // DevTools & Cheat Protection - Keyboard and Context Menu Disabler
    function initSecurity() {
        // 1. Disable context menu (right click)
        document.addEventListener('contextmenu', e => e.preventDefault());

        // 2. Disable devtools shortcut keys (F12, Ctrl+Shift+I, Ctrl+Shift+J, Ctrl+Shift+C, Ctrl+U)
        document.addEventListener('keydown', e => {
            if (
                e.key === 'F12' || 
                (e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'i' || e.key === 'J' || e.key === 'j' || e.key === 'C' || e.key === 'c')) ||
                (e.ctrlKey && (e.key === 'U' || e.key === 'u'))
            ) {
                e.preventDefault();
                return false;
            }
        });
    }

    // Initialize anti-cheating mechanisms immediately
    initSecurity();

    startBtn.onclick = async () => {
        if (!operatorName) return;
        bootingScreen.classList.remove('hidden');
        setTimeout(() => bootingScreen.classList.add('opacity-100'), 50);

        // Shuffle and choose 50 questions
        const shuffled = [...soalDatabase].sort(() => Math.random() - 0.5);
        const selected = shuffled.slice(0, 50);
        const categoryOrder = ['IoT', 'Game', 'Web', 'Logika', 'Inovatif'];
        activeQuestions = selected.sort((a, b) => categoryOrder.indexOf(a.category) - categoryOrder.indexOf(b.category));
        
        userSelections = new Array(activeQuestions.length).fill(null);
        isCorrectArray = new Array(activeQuestions.length).fill(null);
        currentIdx = 0;
        operatorLabel.textContent = operatorName.toUpperCase();

        setTimeout(() => {
            bootingScreen.classList.remove('opacity-100');
            bootingScreen.classList.add('opacity-0');
            setTimeout(() => {
                bootingScreen.classList.add('hidden');
                introCard.classList.add('hidden');
                quizInterface.classList.remove('hidden');
                setTimeout(() => {
                    quizInterface.classList.remove('opacity-0');
                    render();
                }, 50);
            }, 500);
        }, 1200);
    };

    function updateStats() {
        const statsContainer = document.getElementById('categories-stat');
        if (!statsContainer) return;
        statsContainer.innerHTML = '';
        
        const cats = ['IoT', 'Game', 'Web', 'Logika', 'Inovatif'];
        cats.forEach(cat => {
            const val = proficiency[cat] || 0;
            const item = document.createElement('div');
            item.className = 'space-y-1.5';
            item.innerHTML = `
                <div class="flex justify-between text-xs">
                    <span class="font-bold text-slate-300">${cat}</span>
                    <span class="font-semibold text-slate-400">${val}%</span>
                </div>
                <div class="h-1.5 w-full bg-slate-950 rounded-full overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-500" style="width: ${val}%; background-color: ${themeMap[cat].color}"></div>
                </div>
            `;
            statsContainer.appendChild(item);
        });
    }

    function render() {
        const q = activeQuestions[currentIdx];
        const theme = themeMap[q.category];
        
        // Dynamically update theme variables
        root.style.setProperty('--accent', theme.color);
        
        mascotImg.src = mascotMap[q.category] || '/the_tinkers.png';
        catBadge.textContent = `Kategori: ${q.category}`;
        currentNum.textContent = String(currentIdx + 1).padStart(2, '0');
        
        // Escaping HTML characters via textContent for safety and clean render
        questionText.textContent = q.question;
        
        const progress = Math.round((currentIdx / activeQuestions.length) * 100);
        progressBar.style.width = `${progress}%`;
        progressPercent.textContent = `${progress}%`;

        updateStats();

        optionsGrid.innerHTML = '';
        q.options.forEach((opt, i) => {
            const btn = document.createElement('button');
            const isSelected = userSelections[currentIdx] === opt;
            
            btn.className = `group relative p-5 transition-all border rounded-2xl text-left overflow-hidden ${
                isSelected 
                ? 'bg-indigo-600 border-indigo-500 text-white shadow-lg shadow-indigo-600/30' 
                : 'bg-slate-900/40 border-slate-800/80 text-slate-300 hover:border-slate-700 hover:bg-slate-900/60'
            }`;
            
            btn.innerHTML = `
                <div class="relative z-10 flex items-center space-x-4">
                    <div class="w-8 h-8 rounded-lg border ${isSelected ? 'border-white/20 bg-white/10 text-white' : 'border-slate-800 bg-slate-950/50 text-slate-400'} flex items-center justify-center font-bold text-xs">
                        ${String.fromCharCode(65 + i)}
                    </div>
                    <span class="text-sm font-semibold tracking-wide flex-1 option-text"></span>
                </div>
            `;
            
            // Set option text using textContent to prevent HTML tag parsing bug
            btn.querySelector('.option-text').textContent = opt;
            
            btn.onclick = async () => {
                userSelections[currentIdx] = opt;
                
                // Securely check if option is correct
                const hashedOpt = await sha256(`${q.id}-${opt}-${SALT}`);
                const isCorrect = hashedOpt === q.answerHash;
                isCorrectArray[currentIdx] = isCorrect;
                
                // Recalculate proficiency based on current correct answers
                proficiency = { 'IoT': 0, 'Game': 0, 'Web': 0, 'Logika': 0, 'Inovatif': 0 };
                activeQuestions.forEach((question, idx) => {
                    if (isCorrectArray[idx] === true) {
                        proficiency[question.category] = (proficiency[question.category] || 0) + 10;
                    }
                });

                render();
                
                setTimeout(() => {
                    if (currentIdx < activeQuestions.length - 1) {
                        currentIdx++;
                        render();
                    }
                }, 200);
            };
            optionsGrid.appendChild(btn);
        });

        prevBtn.disabled = currentIdx === 0;
        nextBtn.disabled = userSelections[currentIdx] === null;
    }

    startBtn.disabled = true;
    nameInput?.addEventListener('input', (e) => {
        operatorName = e.target.value.trim();
        startBtn.disabled = operatorName.length < 3;
    });

    nextBtn.onclick = () => {
        if (currentIdx < activeQuestions.length - 1) {
            currentIdx++;
            render();
        } else {
            finish();
        }
    };

    prevBtn.onclick = () => {
        if (currentIdx > 0) {
            currentIdx--;
            render();
        }
    };

    function finish() {
        let score = 0;
        isCorrectArray.forEach(val => {
            if (val === true) score++;
        });

        const accuracy = Math.round((score / activeQuestions.length) * 100);
        finalOperator.textContent = operatorName.toUpperCase();
        
        quizInterface.classList.add('opacity-0');
        setTimeout(() => {
            quizInterface.classList.add('hidden');
            resultScreen.classList.remove('hidden');
            setTimeout(() => {
                resultScreen.classList.remove('opacity-0');
                finalScoreVal.textContent = score;
                accuracyVal.textContent = `${accuracy}%`;
                
                if (accuracy === 100) rankTitle.textContent = "THE SINGULARITY";
                else if (accuracy >= 85) rankTitle.textContent = "GRAND OVERSEER";
                else if (accuracy >= 60) rankTitle.textContent = "SYSTEM ELITE";
                else rankTitle.textContent = "PROTO NODE";
            }, 50);
        }, 500);
    }

    restartBtn.onclick = () => location.reload();
</script>

<style is:global>
    body {
        background-color: #090d16;
        overscroll-behavior: none;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #090d16; }
    ::-webkit-scrollbar-thumb { background: #312e81; border-radius: 9999px; }
    ::-webkit-scrollbar-thumb:hover { background: #4338ca; }
</style>
